# Orchestrator Service Configuration

# Application
APP_NAME=orchestrator-service
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# API
API_V1_PREFIX=/api/v1

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256

# External Services URLs (set to enable real API calls)
# Leave empty or unset to use mock mode
AUTH_SERVICE_URL=http://auth-service:8080
QUERY_SERVICE_URL=http://query-service:8080
RAG_SERVICE_URL=http://rag-service:8081
OCR_SERVICE_URL=http://ocr-service:8083
VALIDATE_SERVICE_URL=http://validation-service:8082
INTEGRATION_SERVICE_URL=http://integration-service:8084

# Mock Mode (true = use mocks, false = call real services)
# If service URL is not set, mock mode is used automatically
AUTH_SERVICE_MOCK=true
QUERY_SERVICE_MOCK=true
RAG_SERVICE_MOCK=true
OCR_SERVICE_MOCK=true
VALIDATE_SERVICE_MOCK=true
INTEGRATION_SERVICE_MOCK=true
