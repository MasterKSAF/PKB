# Database
DATABASE_URL=postgresql+asyncpg://pkb:pkb@localhost:5432/pkb_query

# Service
APP_HOST=0.0.0.0
APP_PORT=8083
CORS_ORIGINS=http://localhost:3010,http://localhost:3000

# Auth
DEV_AUTH_MODE=true

# Mock flags (true = использовать заглушки, false = реальные сервисы)
MOCK_RAG_ENABLED=true
MOCK_REGISTRY_ENABLED=true
MOCK_LLM_ENABLED=true

# Internal service URLs (используются когда MOCK_*=false)
RAG_SERVICE_URL=http://localhost:8091/api/v1
REGISTRY_SERVICE_URL=http://localhost:8084/api/v1

# LLM (используется когда MOCK_LLM_ENABLED=false)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6
