# =============================================================================
# RAG Search Service Configuration
# =============================================================================

# --- Service ---
SERVICE_NAME=rag-search
SERVICE_VERSION=0.1.0
SERVICE_PORT=8091
LOG_LEVEL=INFO
LOG_PII_FIELDS=password,access_token,refresh_token

# --- Database ---
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=knowledge_base
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432  # 5433 локально, чтобы не конфликктовать с Postgres
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# --- Embedding Provider ---
# Если EMBEDDING_API_KEY пустой → используется локальная HuggingFace модель
# Если заполнен → используется OpenAI-compatible API
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# ВАЖНО: Размерность должна совпадать с моделью и схемой БД (VECTOR(1024))
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT=30

# --- Search ---
SEARCH_DEFAULT_TOP_K=10
SEARCH_MAX_TOP_K=100
SEARCH_RRF_K=60
SEARCH_FETCH_MULTIPLIER=2

# --- Health Check ---
HEALTH_CHECK_TIMEOUT=5

# --- HuggingFace Cache (Windows fix) ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1